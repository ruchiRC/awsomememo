# Prisma(서버) — 직접 연결 또는 Session pooler (P1001 시 풀러로 변경)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# 선택: Supabase JS 클라이언트용
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# NextAuth (AUTH_URL은 /api/auth까지 포함)
AUTH_SECRET=""
AUTH_URL="http://localhost:3001/api/auth"
NEXTAUTH_URL="http://localhost:3001"

# --- Vercel: 대시보드 Environment Variables에 DATABASE_URL + AUTH_SECRET 필수
# *.vercel.app 만 쓰면 NEXTAUTH_URL/AUTH_URL 은 빌드 시 자동 보정 (docs/VERCEL.md)
